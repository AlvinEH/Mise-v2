rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && resource != null && 'userId' in resource.data && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "alvin.e.huang@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidRecipe(data) {
      let required = ['title', 'instructions', 'userId', 'createdAt', 'updatedAt'];
      let optional = ['sourceUrl', 'tags', 'servings', 'ingredients', 'ingredientSections'];
      return data.keys().hasAll(required) &&
             data.keys().size() <= 10 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             (!('ingredients' in data) || (data.ingredients is list && data.ingredients.size() < 100)) &&
             (!('ingredientSections' in data) || (data.ingredientSections is list && data.ingredientSections.size() < 20)) &&
             data.instructions is string && data.instructions.size() < 10000 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time &&
             data.updatedAt == request.time &&
             (!('servings' in data) || (data.servings is string && data.servings.size() < 100)) &&
             (!('sourceUrl' in data) || (data.sourceUrl is string && data.sourceUrl.size() < 500)) &&
             (!('tags' in data) || (data.tags is list));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.keys().size() <= 5 &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    function isValidStoreList(data) {
      return data.keys().hasAll(['name', 'userId', 'createdAt']) &&
             data.keys().size() <= 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidShoppingItem(data) {
      let required = ['storeListId', 'name', 'completed', 'order', 'userId', 'createdAt'];
      return data.keys().hasAll(required) &&
             data.keys().size() <= 9 &&
             data.storeListId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.completed is bool &&
             data.order is int &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidMealEntry(data) {
      return data.keys().hasAll(['userId', 'date', 'type', 'recipeName', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 9 &&
             data.userId == request.auth.uid &&
             data.date is string && data.date.size() == 10 &&
             data.type in ['lunch', 'dinner'] &&
             data.recipeName is string && data.recipeName.size() > 0 && data.recipeName.size() < 200 &&
             data.createdAt == request.time &&
             data.updatedAt == request.time &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 1000));
    }

    function isValidInventoryItem(data) {
      return data.keys().hasAll(['name', 'category', 'userId', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 12 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.category in ['ingredient', 'supply'] &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidGeminiSettings(data) {
      return data.keys().hasAll(['apiKey', 'updatedAt']) &&
             data.keys().size() == 2 &&
             data.apiKey is string && data.apiKey.size() > 0 && data.apiKey.size() < 200 &&
             data.updatedAt == request.time;
    }

    function isValidUserPreferences(data) {
      let required = ['theme', 'mode', 'checkboxStyle', 'aiAutoSort', 'updatedAt'];
      return data.keys().hasAll(required) &&
             data.keys().size() == 5 &&
             data.theme is string &&
             data.mode is string &&
             data.checkboxStyle is string &&
             data.aiAutoSort is bool &&
             data.updatedAt == request.time;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isAdmin() || isOwner(userId);
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if (isAdmin() || (isOwner(userId) && incoming().role == existing().role)) && isValidUser(incoming());
      
      match /settings/gemini {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidGeminiSettings(incoming());
        allow delete: if isOwner(userId);
      }

      match /settings/preferences {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidUserPreferences(incoming());
        allow delete: if isOwner(userId);
      }
    }

    match /recipes/{recipeId} {
      allow read: if isAuthenticated() && (isAdmin() || existing().userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidId(recipeId) && isValidRecipe(incoming());
      allow update: if isAuthenticated() && isValidId(recipeId) && 
                    (isAdmin() || (isDocOwner() && incoming().userId == existing().userId && incoming().createdAt == existing().createdAt)) &&
                    incoming().updatedAt == request.time &&
                    (isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'instructions', 'ingredientSections', 'servings', 'sourceUrl', 'tags', 'updatedAt']));
      allow delete: if isAuthenticated() && isValidId(recipeId) && (isAdmin() || isDocOwner());
    }

    match /storeLists/{listId} {
      allow read: if isAuthenticated() && (isAdmin() || existing().userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidId(listId) && isValidStoreList(incoming());
      allow update: if isAuthenticated() && isValidId(listId) && isDocOwner() && 
                    incoming().userId == existing().userId && incoming().createdAt == existing().createdAt &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']);
      allow delete: if isAuthenticated() && isValidId(listId) && (isAdmin() || isDocOwner());
    }

    match /shoppingItems/{itemId} {
      allow read: if isAuthenticated() && (isAdmin() || existing().userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidId(itemId) && isValidShoppingItem(incoming());
      allow update: if isAuthenticated() && isValidId(itemId) && isDocOwner() && 
                    incoming().userId == existing().userId && incoming().createdAt == existing().createdAt &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'completed', 'order', 'amount', 'unit', 'updatedAt', 'storeListId']);
      allow delete: if isAuthenticated() && isValidId(itemId) && (isAdmin() || isDocOwner());
    }

    match /mealEntries/{entryId} {
      allow read: if isAuthenticated() && (isAdmin() || existing().userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidId(entryId) && isValidMealEntry(incoming());
      allow update: if isAuthenticated() && isValidId(entryId) && (isAdmin() || isDocOwner()) &&
                    incoming().userId == existing().userId && incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['recipeName', 'notes', 'updatedAt', 'recipeId', 'date', 'type']);
      allow delete: if isAuthenticated() && isValidId(entryId) && (isAdmin() || isDocOwner());
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated() && (isAdmin() || existing().userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidId(itemId) && isValidInventoryItem(incoming());
      allow update: if isAuthenticated() && isValidId(itemId) && isDocOwner() && 
                    incoming().userId == existing().userId && incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'category', 'quantity', 'unit', 'location', 'purchasedOn', 'notes', 'used', 'updatedAt', 'order']);
      allow delete: if isAuthenticated() && isValidId(itemId) && (isAdmin() || isDocOwner());
    }

    match /inventoryLocations/{locationId} {
      allow read: if isAuthenticated() && (isAdmin() || existing().userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidId(locationId) && 
                    incoming().keys().hasAll(['name', 'category', 'userId', 'createdAt']) &&
                    incoming().userId == request.auth.uid && incoming().createdAt == request.time;
      allow update: if isAuthenticated() && isValidId(locationId) && isDocOwner() && 
                    incoming().userId == existing().userId && incoming().createdAt == existing().createdAt &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'category', 'order']);
      allow delete: if isAuthenticated() && isValidId(locationId) && (isAdmin() || isDocOwner());
    }

    match /inventoryAutoSortRules/{ruleId} {
      allow read: if isAuthenticated() && (isAdmin() || existing().userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidId(ruleId) && 
                    incoming().keys().hasAll(['keyword', 'location', 'category', 'userId', 'createdAt']) &&
                    incoming().userId == request.auth.uid && incoming().createdAt == request.time;
      allow update: if isAuthenticated() && isValidId(ruleId) && isDocOwner() && 
                    incoming().userId == existing().userId && incoming().createdAt == existing().createdAt &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['keyword', 'location', 'category', 'updatedAt']);
      allow delete: if isAuthenticated() && isValidId(ruleId) && (isAdmin() || isDocOwner());
    }
  }
}
